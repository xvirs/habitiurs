<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Habitiurs.AppWidgetContainer"
    android:padding="@dimen/widget_margin"
    android:background="@drawable/app_widget_background_v2"> <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hábitos de Hoy"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white" android:gravity="center_horizontal" />

        <ImageView
            android:id="@+id/refresh_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:background="@drawable/refresh_button_background" android:src="@drawable/ic_refresh"
            android:contentDescription="Actualizar hábitos"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <ListView
        android:id="@+id/habits_listview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/widget_header"
        android:layout_alignParentBottom="true"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        tools:listitem="@layout/widget_habit_item"/>

    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_header"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:text="No hay hábitos activos para hoy. Agrega uno en la app!"
        android:textColor="@color/grey_400" android:textSize="14sp"
        android:visibility="gone" />

</RelativeLayout>