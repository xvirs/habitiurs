<?xml version="1.0" encoding="utf-8"?>
<!-- Solo para la previsualización del selector de widgets (datos de muestra). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hábitos de hoy"
            android:textColor="@color/w_on_surface"
            android:textStyle="bold"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3/5"
            android:textColor="@color/w_accent"
            android:textStyle="bold"
            android:textSize="14sp" />
    </LinearLayout>

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginTop="7dp"
        android:layout_marginBottom="6dp"
        android:max="100"
        android:progress="60"
        android:progressDrawable="@drawable/widget_progress" />

    <!-- Fila muestra 1 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
        <ImageView android:layout_width="11dp" android:layout_height="11dp"
            android:src="@drawable/widget_dot" android:layout_marginEnd="12dp"
            android:contentDescription="@null"
            app:tint="#FF2E7D32" xmlns:app="http://schemas.android.com/apk/res-auto" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Gimnasio" android:textColor="@color/w_on_surface_var" android:textSize="15sp" />
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_check_done" android:contentDescription="@null" />
    </LinearLayout>

    <!-- Fila muestra 2 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
        <ImageView android:layout_width="11dp" android:layout_height="11dp"
            android:src="@drawable/widget_dot" android:layout_marginEnd="12dp"
            android:contentDescription="@null"
            app:tint="#FF1565C0" xmlns:app="http://schemas.android.com/apk/res-auto" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Leer 20 min" android:textColor="@color/w_on_surface" android:textSize="15sp" />
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_check_todo" android:contentDescription="@null" />
    </LinearLayout>

    <!-- Fila muestra 3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="7dp">
        <ImageView android:layout_width="11dp" android:layout_height="11dp"
            android:src="@drawable/widget_dot" android:layout_marginEnd="12dp"
            android:contentDescription="@null"
            app:tint="#FFEF6C00" xmlns:app="http://schemas.android.com/apk/res-auto" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Meditar" android:textColor="@color/w_on_surface" android:textSize="15sp" />
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_check_todo" android:contentDescription="@null" />
    </LinearLayout>

</LinearLayout>
